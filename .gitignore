cd /srv/cryptoteh
cat > .gitignore <<'EOF'
# === Общие исключения ===
*.log
.DS_Store
Thumbs.db
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.env
.env.local
.env.production.local
.env.development.local
.env.test.local
.env.example

# === Node.js ===
node_modules/
package-lock.json

# === Build и временные файлы ===
.tmp/
build/
dist/
.cache/
coverage/
out/

# === IDE и редакторы ===
.idea/
.vscode/
*.swp
*.sublime-project
*.sublime-workspace


# === Next.js (client) ===
/client/.next/
/client/.vercel/
/client/public/static/
/client/public/build/
/client/*.pid

# === Strapi (server) ===
/server/.strapi-updater.json
/server/.tmp/
/server/build/
/server/public/uploads/

# SQLite database (WAL mode)
/server/database/*.db
/server/database/*.db-shm
/server/database/*.db-wal
/server/public/**/*.tmp
/server/public/**/*.bak
/server/public/**/*.zip

# Strapi build artifacts
/server/src/plugins/sitemap/server/services/sitemap.json
/server/strapi/client/
/server/.strapi/
/server/.cache/
/server/build/
/server/.tmp/

/server/types/generated/
/server/exports/
/server/dist/

# === API-сервис ===
/api/node_modules/
/api/dist/
/api/build/
/api/Untitled-1.yaml
/api/demodata.json

# === Разное ===
*.bak
*.old
*.swp
*.lock
*.sqlite-journal
*.tar.gz
*.zip
*.zst
*.sql
*.dump
*.tgz
