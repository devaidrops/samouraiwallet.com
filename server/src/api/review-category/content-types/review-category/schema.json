{
  "kind": "collectionType",
  "collectionName": "review_categories",
  "info": {
    "singularName": "review-category",
    "pluralName": "review-categories",
    "displayName": "Review Category",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "meta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.meta"
    },
    "title": {
      "type": "string"
    },
    "content": {
      "type": "customField",
      "options": {
        "preset": "custom"
      },
      "customField": "plugin::ckeditor5video.CKEditor5Video"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "review_category"
    },
    "slug": {
      "type": "string"
    },
    "aux_reviews": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::review.review",
      "mappedBy": "review_categories"
    },
    "threads": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::thread.thread",
      "inversedBy": "review_categories"
    }
  }
}
