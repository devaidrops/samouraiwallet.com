{
  "kind": "collectionType",
  "collectionName": "reviews",
  "info": {
    "singularName": "review",
    "pluralName": "reviews",
    "displayName": "Review",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "is_indexed_value": {
      "type": "integer",
      "default": 0,
      "visible": false,
      "required": true
    },
    "meta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.meta"
    },
    "slug": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "rating": {
      "type": "decimal"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "summary": {
      "displayName": "Summary Rating",
      "type": "component",
      "repeatable": true,
      "component": "review.summary-rating"
    },
    "external_link": {
      "type": "string"
    },
    "pros": {
      "displayName": "ProsCons",
      "type": "component",
      "repeatable": true,
      "component": "review.pros-cons"
    },
    "cons": {
      "type": "component",
      "repeatable": true,
      "component": "review.pros-cons"
    },
    "content": {
      "type": "customField",
      "options": {
        "preset": "custom"
      },
      "customField": "plugin::ckeditor5video.CKEditor5Video"
    },
    "review_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::review-category.review-category",
      "inversedBy": "reviews"
    },
    "trigger_values": {
      "displayName": "Trigger Value",
      "type": "component",
      "repeatable": false,
      "component": "review.trigger-value"
    },
    "company_info": {
      "displayName": "Company Info",
      "type": "component",
      "repeatable": true,
      "component": "review.company-info"
    },
    "comments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::comment.comment",
      "mappedBy": "review"
    },
    "review_categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::review-category.review-category",
      "inversedBy": "aux_reviews"
    },
    "allow_thread": {
      "type": "boolean",
      "default": true,
      "required": false
    },
    "threaded_comment": {
      "type": "string",
      "pluginOptions": {
        "all-featured-parent-comment": {
          "enabled": true
        }
      }
    },
    "random_avatar_name_pair": {
      "type": "text",
      "pluginOptions": {
        "avatar-name-pairs-monitor": {
          "enabled": true
        }
      }
    }
  }
}
