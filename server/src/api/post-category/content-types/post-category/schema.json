{
  "kind": "collectionType",
  "collectionName": "post_categories",
  "info": {
    "singularName": "post-category",
    "pluralName": "post-categories",
    "displayName": "Post Category",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "meta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.meta"
    },
    "title": {
      "type": "string"
    },
    "posts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::post.post",
      "mappedBy": "post_category"
    },
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "threads": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::thread.thread",
      "mappedBy": "post_categories"
    },
    "description": {
      "type": "customField",
      "options": {
        "preset": "custom"
      },
      "customField": "plugin::ckeditor5video.CKEditor5Video"
    }
  }
}
